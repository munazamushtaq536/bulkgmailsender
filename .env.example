# VERCEL ENVIRONMENT VARIABLES
# Add these in your Vercel Dashboard under: Settings -> Environment Variables
# After adding them in Vercel, also create a local .env file with the same values for local testing

# ------------------------------------------------------------------
# Vercel Postgres (auto-generated when you connect a Postgres database in Vercel Dashboard)
# ------------------------------------------------------------------
POSTGRES_URL=your_vercel_postgres_connection_string
POSTGRES_PRISMA_URL=your_vercel_postgres_prisma_url
POSTGRES_URL_NON_POOLING=your_vercel_postgres_url_non_pooling
POSTGRES_USER=your_postgres_user
POSTGRES_HOST=your_postgres_host
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DATABASE=your_postgres_database

# ------------------------------------------------------------------
# Vercel KV (auto-generated when you connect a KV store in Vercel Dashboard)
# ------------------------------------------------------------------
KV_URL=your_vercel_kv_url
KV_REST_API_URL=your_vercel_kv_rest_api_url
KV_REST_API_TOKEN=your_vercel_kv_rest_api_token
KV_REST_API_READ_ONLY_TOKEN=your_vercel_kv_read_only_token

# ------------------------------------------------------------------
# Optional: Google OAuth (for server-side auth if needed)
# ------------------------------------------------------------------
# CLIENT_ID=your_google_client_id
# CLIENT_SECRET=your_google_client_secret
